# NAS Docker 主厨登录；至少 10 位。不要把真实值提交到代码仓库。
CHEF_PASSWORD=

# 可留空；NAS 首次运行时会自动生成并保存在数据目录。
SESSION_SECRET=

# 通义千问 Qwen3-VL-Plus 菜谱截图识别，仅服务器端使用。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-vl-plus
# 可选：只覆盖菜谱识别模型；通常留空即可。
OPENAI_RECIPE_MODEL=

# 本机开发默认 ./data；Docker 中固定为 /data。
DATA_DIR=./data
