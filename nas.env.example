# 复制为 .env 后填写。不要把 .env 上传到 GitHub。
APP_PORT=3099
CHEF_PASSWORD=请改成至少10位且只有你知道的密码

# 留空时首次启动会在 NAS 数据目录自动生成并持久保存。
SESSION_SECRET=

# 通义千问 Qwen3-VL-Plus 菜谱截图识别；不填写 Key 仍可使用文字解析模式。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-vl-plus
OPENAI_RECIPE_MODEL=

# 在极空间 Docker 的 Compose 页面中改成你选择的实际文件夹。
NAS_DATA_PATH=./nas-data
NAS_BACKUP_PATH=./nas-backups

# 一般保持默认；遇到目录权限问题时改为极空间对应用户的 UID/GID。
PUID=1000
PGID=1000

BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_HOURS=24
